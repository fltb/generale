{
  "name": "generale-game-monorepo",
  "module": "index.ts",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "private": true,
  "scripts": {
    "build": "bun run --filter=./packages/* build",
    "dev": "bun run --filter=./packages/* dev",
    "test": "bun run --filter=./packages/* test",
    "typecheck": "bun run --filter=./packages/* typecheck",
    "lint": "bunx biome lint",
    "format": "bunx biome format --write",
    "check": "bunx biome check",
    "check:write": "bunx biome check --write",
    "ci:lint": "bunx biome ci --reporter=github"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}
